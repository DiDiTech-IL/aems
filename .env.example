# Copy this to .env and fill in values before running docker-compose

# ─── Secrets (REQUIRED) ───────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_in_production
REDIS_PASSWORD=change_me_in_production
# Must be at least 32 characters
JWT_SECRET=change_me_in_production_min_32_chars_long

# ─── API (optional overrides) ─────────────────────────────────────────────────
DATABASE_URL=postgresql://aems:${POSTGRES_PASSWORD}@localhost:5432/aems
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379
AI_BASE_URL=http://localhost:8080
LOG_LEVEL=info
PORT=3001
HOST=0.0.0.0

# ─── Web ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

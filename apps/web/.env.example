# ─────────────────────────────────────────────────────────────────────────────
# AEMS — Next.js environment variables
#
# For local development:  copy to .env.local and adjust values.
# For Vercel deployment:  add each variable in the Vercel project dashboard
#   (Settings → Environment Variables) or via the Vercel CLI:
#   vercel env add VARIABLE_NAME
# ─────────────────────────────────────────────────────────────────────────────

# ─── PUBLIC (baked into the client bundle at build time) ─────────────────────

# Public base URL of the Fastify API.
# • Local dev:   http://localhost:3001
# • Production:  https://api.simulance.app
#
# Used by the Next.js rewrite rule (/api/* → API). Must be set at BUILD time.
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket base URL. The browser opens this connection directly.
# • Local dev:   ws://localhost:3001
# • Production:  wss://api.simulance.app
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ─── SERVER-SIDE ONLY (Server Components + Server Actions) ───────────────────

# Internal URL used by Next.js server-side code (Server Components, Server Actions).
# Never exposed to the browser bundle.
# • Local dev:   http://localhost:3001
# • Production:  https://api.simulance.app
API_INTERNAL_URL=http://localhost:3001

# ─── VERCEL PRODUCTION VALUES (simulance.app) ────────────────────────────────
# Add these in Vercel → Project → Settings → Environment Variables,
# scoped to Production (and optionally Preview):
#
#   NEXT_PUBLIC_API_URL   = https://api.simulance.app
#   NEXT_PUBLIC_WS_URL    = wss://api.simulance.app
#   API_INTERNAL_URL      = https://api.simulance.app
#
# Vercel build config is in /vercel.json at the monorepo root.
# DNS: point simulance.app (A/CNAME) to Vercel from the simulance.app registrar.

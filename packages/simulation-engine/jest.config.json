{
  "preset": "ts-jest/presets/default-esm",
  "extensionsToTreatAsEsm": [".ts"],
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "transform": {
    "^.+\\.tsx?$": [
      "ts-jest",
      {
        "useESM": true,
        "tsconfig": "./tsconfig.json"
      }
    ]
  },
  "testMatch": ["**/src/**/*.test.ts"],
  "collectCoverageFrom": ["src/**/*.ts", "!src/**/*.test.ts", "!src/index.ts"]
}

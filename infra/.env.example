# ─────────────────────────────────────────────────────────────────────────────
# AEMS — Server-layer environment configuration
# Copy this file to .env in the same directory and fill in every value.
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── REQUIRED SECRETS ────────────────────────────────────────────────────────
# Generate secure random values:
#   openssl rand -base64 24   (for passwords)
#   openssl rand -base64 32   (for JWT secret — must be ≥ 32 chars)

POSTGRES_PASSWORD=
REDIS_PASSWORD=
JWT_SECRET=

# ─── PUBLIC DOMAIN (Caddy HTTPS via Let's Encrypt) ───────────────────────────
# Set to the hostname where the API will be publicly accessible.
# Caddy will automatically obtain a TLS certificate from Let's Encrypt.
# For local / Docker-only use, set DOMAIN=:80 to stay on plain HTTP.

DOMAIN=api.simulance.app

# Email for Let's Encrypt expiry notifications
CADDY_EMAIL=admin@simulance.app

# ─── CROSS-ORIGIN CONFIGURATION ──────────────────────────────────────────────
# The Next.js frontend is on Vercel at simulance.app — a different origin from
# the API. Set this so the Fastify CORS policy allows browser requests from it.
# The simulation WebSocket connects directly from the browser to api.simulance.app,
# so this must be set correctly.

CORS_ORIGIN=https://simulance.app

# ─── OPTIONAL TUNING ─────────────────────────────────────────────────────────

# JWT token lifetime (default: 8h)
JWT_EXPIRY=8h

# bcrypt work factor for password hashing (10–14; higher = slower but harder to brute-force)
BCRYPT_ROUNDS=12

# API log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# ─── REFERENCE: vars injected automatically by docker-compose ─────────────────
# These are constructed from the secrets above — do not set them manually.
#
#   DATABASE_URL  = postgresql://aems:${POSTGRES_PASSWORD}@postgres:5432/aems
#   REDIS_URL     = redis://:${REDIS_PASSWORD}@redis:6379
#   AI_BASE_URL   = http://llama:8080
#   PORT          = 3001
#   HOST          = 0.0.0.0
#   NODE_ENV      = production
